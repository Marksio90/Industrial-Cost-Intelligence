{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" },
    { "name": "DS_LOKI",       "label": "Loki",       "type": "datasource", "pluginId": "loki" }
  ],
  "uid":         "ici-ml-v1",
  "title":       "ICI — ML Cost Prediction",
  "description": "MAPE, drift, model version, cache, inference latency",
  "tags":        ["ici", "ml", "prediction"],
  "refresh":     "1m",
  "time":        { "from": "now-24h", "to": "now" },
  "timezone":    "browser",
  "schemaVersion": 38,

  "templating": {
    "list": [
      {
        "name": "model_version", "label": "Model Version",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(ici_ml_prediction_requests_total, model_version)",
        "multi": true, "includeAll": true
      },
      {
        "name": "material", "label": "Material Category",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(ici_ml_prediction_requests_total, material_category)",
        "multi": true, "includeAll": true
      }
    ]
  },

  "panels": [

    {
      "id": 1, "type": "stat", "title": "MAPE EWMA",
      "description": "Exponentially weighted MAPE — primary model health signal",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "ici_ml_mape_ewma", "legendFormat": "MAPE EWMA" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percentunit",
        "thresholds": { "steps": [
          { "value": null, "color": "green" },
          { "value": 0.10, "color": "yellow" },
          { "value": 0.20, "color": "red" }
        ]}
      }}
    },

    {
      "id": 2, "type": "stat", "title": "Prediction Request Rate",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "sum(rate(ici_ml_prediction_requests_total{model_version=~\"$model_version\"}[5m]))", "legendFormat": "req/s" }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },

    {
      "id": 3, "type": "stat", "title": "Cache Hit Rate",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "rate(ici_ml_cache_hits_total{model_version=~\"$model_version\"}[10m]) / (rate(ici_ml_cache_hits_total{model_version=~\"$model_version\"}[10m]) + rate(ici_ml_cache_misses_total{model_version=~\"$model_version\"}[10m]))",
        "legendFormat": "hit rate"
      }],
      "fieldConfig": { "defaults": { "unit": "percentunit",
        "thresholds": { "steps": [
          { "value": null, "color": "red" },
          { "value": 0.3,  "color": "yellow" },
          { "value": 0.6,  "color": "green" }
        ]}
      }}
    },

    {
      "id": 4, "type": "stat", "title": "P95 Inference Latency",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (le) (rate(ici_ml_prediction_duration_seconds_bucket{model_version=~\"$model_version\"}[5m])))",
        "legendFormat": "P95"
      }],
      "fieldConfig": { "defaults": { "unit": "s",
        "thresholds": { "steps": [
          { "value": null, "color": "green" },
          { "value": 0.25, "color": "yellow" },
          { "value": 1.0,  "color": "red" }
        ]}
      }}
    },

    {
      "id": 5, "type": "stat", "title": "Max Drift PSI",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "max(ici_ml_drift_psi)", "legendFormat": "max PSI" }],
      "fieldConfig": { "defaults": { "unit": "none",
        "thresholds": { "steps": [
          { "value": null, "color": "green" },
          { "value": 0.10, "color": "yellow" },
          { "value": 0.20, "color": "red" }
        ]}
      }}
    },

    {
      "id": 6, "type": "gauge", "title": "Error Budget — MAPE SLO (target < 15%)",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "1 - (clamp_max(ici_ml_mape_ewma, 0.15) / 0.15)", "legendFormat": "budget" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1,
        "thresholds": { "steps": [
          { "value": null, "color": "red" },
          { "value": 0.25, "color": "yellow" },
          { "value": 0.75, "color": "green" }
        ]}
      }},
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true }
    },

    {
      "id": 10, "type": "timeseries", "title": "MAPE EWMA over Time",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "ici_ml_mape_ewma{model_version=~\"$model_version\"}", "legendFormat": "MAPE EWMA {{model_version}}" },
        { "expr": "0.15", "legendFormat": "SLO (15%)" },
        { "expr": "0.20", "legendFormat": "Alert (20%)" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "SLO (15%)" },    "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }, { "id": "custom.lineStyle", "value": { "dash": [5,5], "fill": "dash" } }] },
          { "matcher": { "id": "byName", "options": "Alert (20%)" },  "properties": [{ "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } }, { "id": "custom.lineStyle", "value": { "dash": [5,5], "fill": "dash" } }] }
        ]
      }
    },

    {
      "id": 11, "type": "timeseries", "title": "MAPE Distribution by Material Category",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le, material_category) (rate(ici_ml_prediction_mape_bucket{model_version=~\"$model_version\",material_category=~\"$material\"}[30m])))", "legendFormat": "P50 {{material_category}}" },
        { "expr": "histogram_quantile(0.90, sum by (le, material_category) (rate(ici_ml_prediction_mape_bucket{model_version=~\"$model_version\",material_category=~\"$material\"}[30m])))", "legendFormat": "P90 {{material_category}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },

    {
      "id": 20, "type": "timeseries", "title": "Feature Drift PSI over Time",
      "description": "PSI > 0.1 = moderate, > 0.2 = high (triggers retraining)",
      "gridPos": { "x": 0, "y": 12, "w": 16, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "ici_ml_drift_psi{model_version=~\"$model_version\"}", "legendFormat": "{{feature}}" },
        { "expr": "0.10", "legendFormat": "Moderate threshold" },
        { "expr": "0.20", "legendFormat": "High threshold" }
      ],
      "fieldConfig": { "defaults": { "unit": "none" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Moderate threshold" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }, { "id": "custom.lineStyle", "value": { "dash": [5,5], "fill": "dash" } }] },
          { "matcher": { "id": "byName", "options": "High threshold" },     "properties": [{ "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } }, { "id": "custom.lineStyle", "value": { "dash": [5,5], "fill": "dash" } }] }
        ]
      }
    },

    {
      "id": 21, "type": "table", "title": "Drift Alert Summary",
      "gridPos": { "x": 16, "y": 12, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "topk(10, ici_ml_drift_psi)", "legendFormat": "", "instant": true, "format": "table" }],
      "transformations": [
        { "id": "organize", "options": { "renameByName": { "feature": "Feature", "model_version": "Model", "Value": "PSI" } } },
        { "id": "sortBy", "options": { "fields": [{ "displayName": "PSI", "desc": true }] } }
      ],
      "fieldConfig": { "defaults": { "unit": "none" },
        "overrides": [{ "matcher": { "id": "byName", "options": "PSI" }, "properties": [{ "id": "thresholds", "value": { "steps": [{ "value": null, "color": "green" }, { "value": 0.1, "color": "yellow" }, { "value": 0.2, "color": "red" }] } }, { "id": "custom.displayMode", "value": "color-background" }] }]
      }
    },

    {
      "id": 30, "type": "timeseries", "title": "Inference Latency (P50 / P95 / P99)",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(ici_ml_prediction_duration_seconds_bucket{model_version=~\"$model_version\"}[5m])))", "legendFormat": "P50" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(ici_ml_prediction_duration_seconds_bucket{model_version=~\"$model_version\"}[5m])))", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(ici_ml_prediction_duration_seconds_bucket{model_version=~\"$model_version\"}[5m])))", "legendFormat": "P99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },

    {
      "id": 31, "type": "timeseries", "title": "Predicted Cost Distribution (EUR)",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "histogram_quantile(0.10, sum by (le, material_category) (rate(ici_ml_prediction_value_eur_bucket{material_category=~\"$material\"}[1h])))", "legendFormat": "P10 {{material_category}}" },
        { "expr": "histogram_quantile(0.50, sum by (le, material_category) (rate(ici_ml_prediction_value_eur_bucket{material_category=~\"$material\"}[1h])))", "legendFormat": "P50 {{material_category}}" },
        { "expr": "histogram_quantile(0.90, sum by (le, material_category) (rate(ici_ml_prediction_value_eur_bucket{material_category=~\"$material\"}[1h])))", "legendFormat": "P90 {{material_category}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyEUR" } }
    },

    {
      "id": 40, "type": "logs", "title": "ML Inference Logs (errors only)",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [{
        "expr": "{app=\"ici-ml-inference\"} | json | level=~\"ERROR|WARNING\"",
        "legendFormat": ""
      }],
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "sortOrder": "Descending" }
    }
  ]
}
