# ═══════════════════════════════════════════════════════════════════════════
# ICI Platform — Environment Configuration
# Copy to .env and fill in all required values before running.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════

# ── Project ──────────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=ici
ENVIRONMENT=development            # development | staging | production
APP_VERSION=1.0.0

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ici
POSTGRES_USER=ici
POSTGRES_PASSWORD=changeme_postgres_password
POSTGRES_MAX_CONNECTIONS=200
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=768MB
POSTGRES_WORK_MEM=16MB

# Alembic / SQLAlchemy DSN (internal service network)
DATABASE_URL=postgresql+asyncpg://ici:changeme_postgres_password@postgres:5432/ici
DATABASE_URL_SYNC=postgresql://ici:changeme_postgres_password@postgres:5432/ici

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password
REDIS_MAX_MEMORY=512mb
REDIS_URL=redis://:changeme_redis_password@redis:6379/0

# Per-database URLs
REDIS_CACHE_URL=redis://:changeme_redis_password@redis:6379/0
REDIS_QUEUE_URL=redis://:changeme_redis_password@redis:6379/1
REDIS_PUBSUB_URL=redis://:changeme_redis_password@redis:6379/2

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=changeme_qdrant_api_key
QDRANT_URL=http://qdrant:6333

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_HOST=mlflow
MLFLOW_PORT=5000
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts
MLFLOW_BACKEND_STORE_URI=postgresql://ici:changeme_postgres_password@postgres:5432/ici
MLFLOW_DEFAULT_ARTIFACT_ROOT=s3://ici-mlflow-artifacts   # override for production S3

# ── Backend API ───────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=4
APP_NAME="Industrial Cost Intelligence"
DEBUG=false
LOG_LEVEL=INFO
LOG_JSON=true

# Auth / JWT
SECRET_KEY=changeme_super_secret_jwt_key_at_least_32_chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
ALGORITHM=HS256

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ── ML Inference Service ──────────────────────────────────────────────────────
ML_HOST=0.0.0.0
ML_PORT=8002
ML_WORKERS=2
ML_DATABASE_URL=postgresql+asyncpg://ici:changeme_postgres_password@postgres:5432/ici
ML_REDIS_URL=redis://:changeme_redis_password@redis:6379/0
ML_MLFLOW_TRACKING_URI=http://mlflow:5000
ML_MLFLOW_REGISTRY_NAME=cost-predictor
ML_USE_MOCK_EMBEDDER=false
VECTOR_BACKEND=pgvector                # pgvector | qdrant

# ── RFQ Agent ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
RFQ_DATABASE_URL=postgresql+asyncpg://ici:changeme_postgres_password@postgres:5432/ici
RFQ_REDIS_URL=redis://:changeme_redis_password@redis:6379/2
RFQ_SMTP_HOST=smtp.gmail.com
RFQ_SMTP_PORT=587
RFQ_SMTP_USERNAME=
RFQ_SMTP_PASSWORD=
RFQ_SMTP_FROM_EMAIL=procurement@example.com
RFQ_SMTP_FROM_NAME=ICI Procurement
RFQ_IMAP_HOST=imap.gmail.com
RFQ_IMAP_USERNAME=
RFQ_IMAP_PASSWORD=
RFQ_MAX_EMAILS_PER_HOUR=20
RFQ_EMAIL_BACKEND=smtp

# ── Worker (ARQ / background tasks) ──────────────────────────────────────────
WORKER_CONCURRENCY=4
WORKER_QUEUE_URL=redis://:changeme_redis_password@redis:6379/1
WORKER_MAX_JOBS=100

# ── NGINX ─────────────────────────────────────────────────────────────────────
NGINX_PORT=80
NGINX_SSL_PORT=443
NGINX_CLIENT_MAX_BODY_SIZE=50m

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=ici-backend

PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_grafana_password

# ── Object Storage (production) ───────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
S3_BUCKET_NAME=ici-artifacts
